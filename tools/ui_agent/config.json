{
  "name": "UI Agent",
  "version": 1,
  "build_backend": "github_actions",
  "ignore_local_aapt2": true,
  "vision": {
    "enabled": true,
    "mode": "screenshot"
  },
  "workflow": [
    "capture_ui",
    "analyze_ui",
    "map_to_project_files",
    "create_fix_plan",
    "commit_changes",
    "push_to_github",
    "wait_build_result",
    "analyze_build_log"
  ]
}