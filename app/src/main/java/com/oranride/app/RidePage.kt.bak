package com.oranride.app

import androidx.compose.material3.*
import androidx.compose.runtime.Composable

@Composable
fun RidePage(viewModel: RideViewModel){

    Button(onClick={ viewModel.acceptRide() }){
        Text("قبول الرحلة")
    }

    Button(onClick={ viewModel.rejectRide() }){
        Text("رفض الرحلة")
    }
}